# ============================================
# Sovereign Estate Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in values

# ---- Server ----
NODE_ENV=development
PORT=3000

# ---- Database ----
MONGO_URI=mongodb://localhost:27017/sovereign-estate

# ---- JWT ----
JWT_ACCESS_SECRET=your-access-secret-key-at-least-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-key-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---- CORS ----
CORS_ORIGIN=http://localhost:3001

# ---- Docker Compose (optional) ----
MONGO_USERNAME=admin
MONGO_PASSWORD=password
